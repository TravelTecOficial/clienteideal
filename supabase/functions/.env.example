# Secrets para Edge Functions (desenvolvimento local)
# Copie para .env: cp .env.example .env
# Nunca commite .env no Git.

# Obrigatório para clerk-webhook: igual ao "Signing secret" do Clerk
# Clerk Dashboard > Webhooks > [seu endpoint] > Signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Obrigatório para sync-profile-client: Secret Key do Clerk (chave privada)
# Clerk Dashboard > API Keys > Secret keys
# IMPORTANTE: Configure no Supabase Dashboard:
#   Project Settings > Edge Functions > Secrets > CLERK_SECRET_KEY
# Se não configurado, a página /planos mostrará erro de configuração.
# sync-profile (webhook) usa CLERK_WEBHOOK_SECRET, não CLERK_SECRET_KEY.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Obrigatório para persona-generate-avatar: chave da Stability AI
# Obtenha em https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Obrigatório para google-oauth: OAuth 2.0 do Google (GA4, Ads, My Business)
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# GOOGLE_REDIRECT_URI deve ser ex: https://seu-dominio.com/auth/google/callback
# GOOGLE_REDIRECT_URI para produção: https://clienteideal.online/auth/google/callback
# GOOGLE_TOKEN_ENCRYPTION_KEY: chave 32 bytes para AES-GCM (não reutilizar META_TOKEN_ENCRYPTION_KEY)
# N8N_META_CONNECTIONS_API_KEY: secret compartilhado para meta-connections-n8n (n8n obtém IDs Meta por company_id)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_TOKEN_ENCRYPTION_KEY=
# GOOGLE_ADS_DEVELOPER_TOKEN: obrigatório para exibir número da conta Google Ads (22 caracteres)
# Obtenha em: Google Ads > Ferramentas > API Center
# GOOGLE_ADS_DEVELOPER_TOKEN=
