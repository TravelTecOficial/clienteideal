# Supabase (obrigatório)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Clerk (obrigatório para /planos)
# Configure um JWT template "supabase" no Clerk para integração com RLS
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Opcional: URL do script clerk-js (sobrescreve o proxy em dev)
# VITE_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js
# Opcional: versão do clerk-js no proxy em dev (default 5; use 6 se o dashboard exigir e testar UI)
# VITE_CLERK_JS_VERSION=5
# Opcional (só dev): URL da Clerk Frontend API para proxy no Vite — evita CORS/530; use o domínio que aparece no erro (ex.: artistic-stingray-67.clerk.accounts.dev)
# VITE_CLERK_FAPI=https://artistic-stingray-67.clerk.accounts.dev

# --- Chat de Conhecimento (webhook N8N Agente de IA) ---
# URL do webhook do n8n para o Chat de Conhecimento (evita CORS em localhost)
VITE_N8N_CHAT_WEBHOOK_URL=https://seu-n8n.com/webhook/seu-webhook-id

# --- GMB Local (Google Maps) ---
# Chave pública para Maps JavaScript API. Use a mesma do Places e habilite "Maps JavaScript API" no Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=
# Map ID (opcional): remove aviso de deprecation do Marker. Crie em: console.cloud.google.com/google/maps-apis/studio/maps (tipo Vector/JavaScript)
VITE_GOOGLE_MAPS_MAP_ID=

# --- Webhook Clerk (Supabase Edge Function) ---
# NÃO coloque isto em .env.local (frontend). Use `supabase secrets set`:
#   supabase secrets set CLERK_WEBHOOK_SECRET=whsec_xxx
# O valor deve ser IDÊNTICO ao "Signing secret" em:
#   Clerk Dashboard > Webhooks > [seu endpoint] > Signing secret
